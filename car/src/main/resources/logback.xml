<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%logger{0}] %-5level %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="com.substation" level="DEBUG"/>

    <!-- 降低第三方库日志级别 -->
    <logger name="redis.clients" level="WARN"/>
    <logger name="com.rabbitmq" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
